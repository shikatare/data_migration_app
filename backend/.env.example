# LLM_PROVIDER: groq (real LLM, needs GROQ_API_KEY) | cortex | mock (offline, no key)
LLM_PROVIDER=groq
GROQ_API_KEY=

# External system modes — flip to real at a client without touching code
ORACLE_MODE=mock
SNOWFLAKE_MODE=mock
SECRETS_MODE=env
STORAGE_MODE=local
NOTIFY_MODE=console

# Optional: force ONE validation failure to demo the self-correction retry loop
FORCE_VALIDATION_FAIL_ONCE=

# Optional integrations
SLACK_WEBHOOK_URL=
AWS_REGION=